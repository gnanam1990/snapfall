CIRCLE_API_KEY=
ARC_TESTNET_RPC=
ARC_CHAIN_ID=5042002
ARC_USDC_ADDRESS=          # real Arc-testnet USDC (verifyingContract). Placeholder until confirmed.
SELLER_ADDRESS=            # where the paid demo API is paid; placeholder default is 0x...dEaD
TREASURY_PRIVATE_KEY=      # testnet only. NEVER a funded mainnet key. Never commit .env.
PAID_API_PORT=4021
SIDECAR_PORT=4020

# H3 payment sidecar (V4) — see docs/handshakes/H3-sidecar-api.md
SIDECAR_AUTH_TOKEN=        # >=32-byte secret; the Funding agent + sidecar only. Bearer auth. Never commit.
H2_APPROVAL_SECRET=        # shared with Gnanam's approval service; HMAC key for approvalToken. Never commit.
SIDECAR_STORE_PATH=        # optional; durable payment record file (default .data/payments.json)
